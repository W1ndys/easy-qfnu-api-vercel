# 服务端口
PORT=8141

# Gin 运行模式 (debug/release)
GIN_MODE=release

# OCR 服务地址（ddddocr-api）
OCR_API_URL=http://localhost:8000

# CORS 允许的源（可选，留空则不启用 CORS）
CORS_ORIGIN=

# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

# 日志格式 (console/json)
LOG_FORMAT=console

# 日志文件路径（留空则仅输出到 stdout）
LOG_FILE=logs

# 单个日志文件最大大小（MB）
LOG_MAX_SIZE=10

# 保留旧日志文件数量
LOG_MAX_BACKUPS=30

# 日志保留天数
LOG_MAX_AGE=30

# 飞书机器人（可选）
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
